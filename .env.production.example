# Môi trường chạy ứng dụng (development / production)
APP_ENV=development

# Cấu hình API Keys của các AI Provider
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Lựa chọn LLM Provider mặc định (google / openai / groq / mock)
TEXT_PROVIDER=google
TEXT_MODEL=gemini-1.5-flash

# Lựa chọn Vector Database mặc định (qdrant / chroma)
VECTOR_STORAGE=qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Cấu hình kết nối Firebase Admin SDK (để xác thực người chơi và admin)
# Tải file JSON credentials từ Firebase Console và khai báo đường dẫn:
FIREBASE_CREDENTIALS_PATH=aistoryadventure-8796e-firebase-adminsdk-fbsvc-f83839518e.json
