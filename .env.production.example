# Copy this file to a real production environment file on the VPS.
# Do not commit real secrets, Firebase admin JSON, or provider API keys.

APP_NAME=AI Story Adventure
APP_ENV=production
STRICT_STARTUP_CHECKS=false
API_PREFIX=

# Lock CORS to the public player/admin origins in production.
CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# AI provider. Keep exactly one provider configured for production.
TEXT_PROVIDER=gemini
TEXT_MODEL=gemini-2.5-flash
GEMINI_API_KEY=replace_with_server_secret

# Optional provider alternatives.
OPENAI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Firebase Admin SDK. Prefer a server-only path on the VPS.
FIREBASE_PROJECT_ID=aistoryadventure-8796e
FIREBASE_CREDENTIALS_PATH=/etc/ai-story/firebase-admin.json
FIREBASE_SERVICE_ACCOUNT_JSON=
FIRESTORE_TIMEOUT_SECONDS=5
USE_LOCAL_STORE_IF_FIREBASE_MISSING=false

# Persistent server paths. Keep these outside the repo on the VPS.
LOCAL_DATA_DIR=/var/lib/ai-story/data
CHROMA_PERSIST_DIR=/var/lib/ai-story/chroma_db

EMBEDDING_PROVIDER=simple
MAX_RECENT_MESSAGES=8
MAX_RELEVANT_MEMORIES=6
