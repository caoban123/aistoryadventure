# Paste these values into Coolify Environment Variables.
# Keep real secrets only in Coolify or on the VPS, never in Git.

APP_NAME=AI Story Adventure
APP_ENV=production
STRICT_STARTUP_CHECKS=false
API_PREFIX=

CORS_ORIGINS=https://aistoryadventure.xyz,https://admin.aistoryadventure.xyz
PUBLIC_API_BASE=https://api.aistoryadventure.xyz

TEXT_PROVIDER=gemini
TEXT_MODEL=gemini-2.5-flash
GEMINI_API_KEY=replace_with_server_secret

OPENAI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

FIREBASE_PROJECT_ID=aistoryadventure-8796e
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace_with_project_id"}
FIREBASE_CREDENTIALS_PATH=
FIRESTORE_TIMEOUT_SECONDS=5
USE_LOCAL_STORE_IF_FIREBASE_MISSING=false

LOCAL_DATA_DIR=/data/ai-story/data
CHROMA_PERSIST_DIR=/data/ai-story/chroma_db
EMBEDDING_PROVIDER=simple
MAX_RECENT_MESSAGES=8
MAX_RELEVANT_MEMORIES=6
KAGGLE_BACKEND_URL=https://prissy-elastic-slang.ngrok-free.dev
